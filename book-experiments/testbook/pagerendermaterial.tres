code = "shader_type canvas_item;



void vertex() {
// Output:0

}

void fragment() {
// Input:7
	vec3 n_out7p0 = COLOR.rgb;

// Texture:3
	vec3 n_out3p0;
	float n_out3p1;
	{
		vec4 _tex_read = texture(TEXTURE , UV.xy);
		n_out3p0 = _tex_read.rgb;
		n_out3p1 = _tex_read.a;
	}

// VectorDecompose:4
	float n_out4p0 = n_out3p0.x;
	float n_out4p1 = n_out3p0.y;
	float n_out4p2 = n_out3p0.z;

// ScalarOp:8
	float n_in8p1 = 0.50000;
	float n_out8p0 = n_out4p0 - n_in8p1;

// Input:15
	vec3 n_out15p0 = vec3(UV, 0.0);

// Input:14
	vec3 n_out14p0 = vec3(TEXTURE_PIXEL_SIZE, 1.0);

// VectorOp:16
	vec3 n_out16p0 = n_out15p0 / n_out14p0;

// VectorDerivativeFunc:13
	vec3 n_out13p0 = fwidth(n_out16p0);

// VectorFunc:21
	vec3 n_out21p0 = abs(n_out13p0);

// VectorDecompose:17
	float n_out17p0 = n_out21p0.x;
	float n_out17p1 = n_out21p0.y;
	float n_out17p2 = n_out21p0.z;

// ScalarOp:18
	float n_out18p0 = max(n_out17p0, n_out17p1);

// ScalarOp:20
	float n_in20p1 = 16.00000;
	float n_out20p0 = n_out18p0 / n_in20p1;

// ScalarClamp:23
	float n_in23p1 = 0.01000;
	float n_in23p2 = 0.99000;
	float n_out23p0 = clamp(n_out20p0, n_in23p1, n_in23p2);

// ScalarOp:19
	float n_out19p0 = n_out8p0 / n_out23p0;

// ScalarOp:11
	float n_in11p1 = 0.50000;
	float n_out11p0 = n_out19p0 + n_in11p1;

// ScalarClamp:22
	float n_in22p1 = 0.00000;
	float n_in22p2 = 1.00000;
	float n_out22p0 = clamp(n_out11p0, n_in22p1, n_in22p2);

// ScalarMix:9
	float n_in9p0 = 0.00000;
	float n_in9p1 = 1.00000;
	float n_out9p0 = mix(n_in9p0, n_in9p1, n_out22p0);

// Output:0
	COLOR.rgb = n_out7p0;
	COLOR.a = n_out9p0;

}

void light() {
// Output:0

}
