# kvbook loader
# written in Udon Assembly because this contains a lot of Unity manipulation and some *nasty* hot loops
# to use, insert the .bytes TextAsset into 'bytesTextAsset', or byte array into 'bytes', set `page`, then call `_LoadPage`
# you can free up memory by strategically calling `_ClearPage` (to free memory) and `_LoadPage` (to rebuild)
# (implementing this on enable/disable automatically was considered, but I've decided to let it be the decision of the host prefab)
# beware: Untrusted content can cause Udon freezes and generation of extremely large meshes. You have been warned.

.data_start

	# -- constants --

	_c_0: %SystemInt32, 0
	_c_1: %SystemInt32, 1
	_c_2: %SystemInt32, 2
	_c_3: %SystemInt32, 3
	_c_4: %SystemInt32, 4
	_c_5: %SystemInt32, 5
	_c_6: %SystemInt32, 6
	_c_8: %SystemInt32, 8
	_c_11: %SystemInt32, 11
	_c_16: %SystemInt32, 16
	_c_31: %SystemInt32, 31
	_c_63: %SystemInt32, 63

	_cf_0: %SystemSingle, 0.0
	_cf_1: %SystemSingle, 1.0
	_cf_31: %SystemSingle, 31.0
	_cf_63: %SystemSingle, 63.0
	_cf_32767: %SystemSingle, 32767.0
	_cf_65535: %SystemSingle, 65535.0

	_null: %SystemObject,null

	# -- public --

	.export page
	page: %SystemInt32, -1

	.export meshFilter
	meshFilter: %UnityEngineMeshFilter, this

	.export meshRenderer
	meshRenderer: %UnityEngineMeshRenderer, this

	.export atlasMaterials
	atlasMaterials: %UnityEngineMaterialArray, null

	.export bytesTextAsset
	bytesTextAsset: %UnityEngineTextAsset, null

	# if bytesTextAsset != null, this only *temporarily* stores the bytes
	# otherwise it always stores the bytes
	.export bytes
	bytes: %SystemByteArray, null

	# -- public out --

	.export infoPageCount
	infoPageCount: %SystemInt32, 0

	.export infoAtlasCount
	infoAtlasCount: %SystemInt32, 0

	.export infoPageWidth
	infoPageWidth: %SystemSingle, 0.0

	.export infoPageHeight
	infoPageHeight: %SystemSingle, 0.0

	.export infoPageSpriteCount
	infoPageSpriteCount: %SystemInt32, 0

	.export infoPageVertexCount
	infoPageVertexCount: %SystemInt32, 0

	.export infoPageIndexCount
	infoPageIndexCount: %SystemInt32, 0

	# -- file offsets --

	# .export _ofsPage
	# .export _endPage
	# .export _ofsAtlas

	_ofsPage: %SystemInt32, 0
	_endPage: %SystemInt32, 0
	_ofsAtlas: %SystemInt32, 0

	_ofsShape: %SystemInt32, 0

	# worth noting, this generator uses Z as 'X' and X as 'Y' to reduce complexity

	# -- erase-me --

	_mesh: %UnityEngineMesh, null
	_material: %UnityEngineMaterial, null

	_vertices: %UnityEngineVector3Array, null
	_triangles: %SystemInt32Array, null
	_colors32: %UnityEngineColor32Array, null
	_uv: %UnityEngineVector2Array, null
	_uv2: %UnityEngineVector2Array, null

	# -- struct sprite --

	# .export _sprShape
	# .export _sprTLX
	# .export _sprTLY
	# .export _sprCol

	_sprShape: %SystemUInt16, null
	_sprTLX: %SystemInt16, null
	_sprTLY: %SystemInt16, null
	_sprCol: %SystemUInt16, null

	# -- struct shape --

	# .export _shpUTLX
	# .export _shpUTLY
	# .export _shpUBRX
	# .export _shpUBRY
	# .export _shpSizeX
	# .export _shpSizeY

	_shpUTLX: %SystemUInt16, null
	_shpUTLY: %SystemUInt16, null
	_shpUBRX: %SystemUInt16, null
	_shpUBRY: %SystemUInt16, null
	_shpSizeX: %SystemSingle, 0.0
	_shpSizeY: %SystemSingle, 0.0

	# -- colour decoding --

	_col_i32: %SystemInt32, 0

	_col_r: %SystemSingle, 0.0
	_col_g: %SystemSingle, 0.0
	_col_b: %SystemSingle, 0.0
	_col: %UnityEngineColor, null
	_col32: %UnityEngineColor32, null

	# -- position calculation --

	_pclTLX: %SystemSingle, 0.0
	_pclTLY: %SystemSingle, 0.0
	_pclBRX: %SystemSingle, 0.0
	_pclBRY: %SystemSingle, 0.0

	# -- uv calculation --

	_uvTLX: %SystemSingle, 0.0
	_uvTLY: %SystemSingle, 0.0
	_uvBRX: %SystemSingle, 0.0
	_uvBRY: %SystemSingle, 0.0

	# -- vertex muxing --

	_vtxV0: %UnityEngineVector3, null
	_vtxT0: %UnityEngineVector2, null
	_vtxV1: %UnityEngineVector3, null
	_vtxT1: %UnityEngineVector2, null
	_vtxV2: %UnityEngineVector3, null
	_vtxT2: %UnityEngineVector2, null
	_vtxV3: %UnityEngineVector3, null
	_vtxT3: %UnityEngineVector2, null

	_vtxUV2: %UnityEngineVector2, null

	# -- indices --

	_vi0: %SystemInt32, 0
	_vi1: %SystemInt32, 0
	_vi2: %SystemInt32, 0
	_vi3: %SystemInt32, 0

	_iptr: %SystemInt32, 0

	# -- temporaries --

	_byte: %SystemByte, null
	_bool: %SystemBoolean, null
	_i32: %SystemInt32, 0
	_floatA: %SystemSingle, 0.0
	_floatB: %SystemSingle, 0.0
	_floatX: %SystemSingle, 0.0
	_floatY: %SystemSingle, 0.0

.data_end
.code_start

	# these functinos have been setup to Do The Right Thing (tm).

.export _start
_start:
	JUMP, _LoadPage

.export _ClearPage
_ClearPage:

	# meshFilter.mesh = null
		PUSH, meshFilter
		PUSH, _null
		EXTERN, "UnityEngineMeshFilter.__set_mesh__UnityEngineMesh__SystemVoid"

_cleanErasable:

	# if bytesTextAsset isn't valid, don't set bytes to null
		PUSH, bytesTextAsset
		PUSH, _bool
		EXTERN, "VRCSDKBaseUtilities.__IsValid__SystemObject__SystemBoolean"
		PUSH, _bool
		JUMP_IF_FALSE, _cleanErasableNotTextAsset

	# bytes = null
		PUSH, _null
		PUSH, bytes
		COPY

_cleanErasableNotTextAsset:

	# _mesh = null
		PUSH, _null
		PUSH, _mesh
		COPY

	# _material = null
		PUSH, _null
		PUSH, _material
		COPY

	# _vertices = null
		PUSH, _null
		PUSH, _vertices
		COPY

	# _triangles = null
		PUSH, _null
		PUSH, _triangles
		COPY

	# _colors32 = null
		PUSH, _null
		PUSH, _colors32
		COPY

	# _uv = null
		PUSH, _null
		PUSH, _uv
		COPY

	# _uv2 = null
		PUSH, _null
		PUSH, _uv2
		COPY

	# end
		JUMP, 0xFFFFFFFC

.export _LoadPage
_LoadPage:

	# -- byte array setup --

		# if bytesTextAsset is valid, we load from there and then clear bytes once we're done.
		# however, someone might be loading book contents dynamically.
		# in *THAT* case, we don't do bytesTextAsset-related things.
			PUSH, bytesTextAsset
			PUSH, _bool
			EXTERN, "VRCSDKBaseUtilities.__IsValid__SystemObject__SystemBoolean"
			PUSH, _bool
			JUMP_IF_FALSE, _loadPageNotTextAsset

		# set up bytes, which lets us read the file.
		# notably, we don't want bytes to be in Udon Heap longer than necessary, as this causes terrible memory use risks if we're instantiated.
		# if it's not from a text asset though, then we don't really have a choice.
			PUSH, bytesTextAsset
			PUSH, bytes
			EXTERN, "UnityEngineTextAsset.__get_bytes__SystemByteArray"

		_loadPageNotTextAsset:

		# bytes might not be valid (say, if we haven't been initialized yet!)
			PUSH, bytes
			PUSH, _bool
			EXTERN, "VRCSDKBaseUtilities.__IsValid__SystemObject__SystemBoolean"
			PUSH, _bool
			JUMP_IF_FALSE, _ClearPage

		# also do this if the length is < 8 (no header)
			PUSH, bytes
			PUSH, _i32
			EXTERN, "SystemByteArray.__get_Length__SystemInt32"
			PUSH, _i32
			PUSH, _c_8
			PUSH, _bool
			EXTERN, "SystemInt32.__op_GreaterThanOrEqual__SystemInt32_SystemInt32__SystemBoolean"
			PUSH, _bool
			JUMP_IF_FALSE, _ClearPage

		# -- setup info --

		# read the atlas count
			PUSH, bytes
			PUSH, _c_0
			PUSH, infoAtlasCount
			EXTERN, "SystemBitConverter.__ToInt32__SystemByteArray_SystemInt32__SystemInt32"

		# read the page count
			PUSH, bytes
			PUSH, _c_4
			PUSH, infoPageCount
			EXTERN, "SystemBitConverter.__ToInt32__SystemByteArray_SystemInt32__SystemInt32"

	# -- validate page number --

		# if the page is < 0, it's definitely not valid, so clear the page
			PUSH, page
			PUSH, _c_0
			PUSH, _bool
			EXTERN, "SystemInt32.__op_GreaterThanOrEqual__SystemInt32_SystemInt32__SystemBoolean"
			PUSH, _bool
			JUMP_IF_FALSE, _ClearPage

		# if the page is >= the page count, it's not valid, so clear the page
			PUSH, page
			PUSH, infoPageCount
			PUSH, _bool
			EXTERN, "SystemInt32.__op_LessThan__SystemInt32_SystemInt32__SystemBoolean"
			PUSH, _bool
			JUMP_IF_FALSE, _ClearPage

	# -- find page lump --

		# _ofsPage = page + atlasCount
			PUSH, page
			PUSH, infoAtlasCount
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# _ofsPage *= 8
			PUSH, _ofsPage
			PUSH, _c_8
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Multiplication__SystemInt32_SystemInt32__SystemInt32"

		# _ofsPage += 8
			PUSH, _ofsPage
			PUSH, _c_8
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# _ofsPage now points to the page's lump offset field

		# _endPage = _ofsPage + 4
			PUSH, _ofsPage
			PUSH, _c_4
			PUSH, _endPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# _endPage now points to the page's lump length field

		# _ofsPage = *_ofsPage
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _ofsPage
			EXTERN, "SystemBitConverter.__ToInt32__SystemByteArray_SystemInt32__SystemInt32"

		# _endPage = *_endPage
			PUSH, bytes
			PUSH, _endPage
			PUSH, _endPage
			EXTERN, "SystemBitConverter.__ToInt32__SystemByteArray_SystemInt32__SystemInt32"

		# _endPage += _ofsPage
			PUSH, _ofsPage
			PUSH, _endPage
			PUSH, _endPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

	# -- find atlas lump --

		# _byte = *_ofsPage ; _ofsPage += 1
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _byte
			EXTERN, "SystemByteArray.__Get__SystemInt32__SystemByte"
			PUSH, _ofsPage
			PUSH, _c_1
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# _ofsAtlas = int32(_byte)
			PUSH, _byte
			PUSH, _ofsAtlas
			EXTERN, "SystemConvert.__ToInt32__SystemByte__SystemInt32"

		# _ofsAtlas = Mathf.Clamp(_ofsAtlas, 0, atlasMaterials.Length - 1)
			PUSH, atlasMaterials
			PUSH, _i32
			EXTERN, "UnityEngineMaterialArray.__get_Length__SystemInt32"
			PUSH, _i32
			PUSH, _c_1
			PUSH, _i32
			EXTERN, "SystemInt32.__op_Subtraction__SystemInt32_SystemInt32__SystemInt32"
			PUSH, _ofsAtlas
			PUSH, _c_0
			PUSH, _i32
			PUSH, _ofsAtlas
			EXTERN, "UnityEngineMathf.__Clamp__SystemInt32_SystemInt32_SystemInt32__SystemInt32"

		# _material = atlasMaterials[_ofsAtlas]
			PUSH, atlasMaterials
			PUSH, _ofsAtlas
			PUSH, _material
			EXTERN, "UnityEngineMaterialArray.__Get__SystemInt32__UnityEngineMaterial"

		# _ofsAtlas *= 8
			PUSH, _ofsAtlas
			PUSH, _c_8
			PUSH, _ofsAtlas
			EXTERN, "SystemInt32.__op_Multiplication__SystemInt32_SystemInt32__SystemInt32"

		# _ofsAtlas += 8
			PUSH, _ofsAtlas
			PUSH, _c_8
			PUSH, _ofsAtlas
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# _ofsAtlas = *_ofsAtlas
			PUSH, bytes
			PUSH, _ofsAtlas
			PUSH, _ofsAtlas
			EXTERN, "SystemBitConverter.__ToInt32__SystemByteArray_SystemInt32__SystemInt32"

	# -- page width/height/sprite count --

		# infoPageWidth = *_ofsPage ; _ofsPage += 4
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, infoPageWidth
			EXTERN, "SystemBitConverter.__ToSingle__SystemByteArray_SystemInt32__SystemSingle"
			PUSH, _ofsPage
			PUSH, _c_4
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# infoPageHeight = *_ofsPage ; _ofsPage += 4
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, infoPageHeight
			EXTERN, "SystemBitConverter.__ToSingle__SystemByteArray_SystemInt32__SystemSingle"
			PUSH, _ofsPage
			PUSH, _c_4
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

		# infoPageSpriteCount = _endPage - _ofsPage
			PUSH, _endPage
			PUSH, _ofsPage
			PUSH, infoPageSpriteCount
			EXTERN, "SystemInt32.__op_Subtraction__SystemInt32_SystemInt32__SystemInt32"

		# infoPageSpriteCount /= 8
			PUSH, infoPageSpriteCount
			PUSH, _c_8
			PUSH, infoPageSpriteCount
			EXTERN, "SystemInt32.__op_Division__SystemInt32_SystemInt32__SystemInt32"

		# infoPageVertexCount = infoPageSpriteCount * 4
			PUSH, infoPageSpriteCount
			PUSH, _c_4
			PUSH, infoPageVertexCount
			EXTERN, "SystemInt32.__op_Multiplication__SystemInt32_SystemInt32__SystemInt32"

		# infoPageIndexCount = infoPageSpriteCount * 6
			PUSH, infoPageSpriteCount
			PUSH, _c_6
			PUSH, infoPageIndexCount
			EXTERN, "SystemInt32.__op_Multiplication__SystemInt32_SystemInt32__SystemInt32"

	# -- create arrays --

		# _vertices = new Vector3[infoPageVertexCount]
			PUSH, infoPageVertexCount
			PUSH, _vertices
			EXTERN, "UnityEngineVector3Array.__ctor__SystemInt32__UnityEngineVector3Array"

		# _uv = new Vector2[infoPageVertexCount]
			PUSH, infoPageVertexCount
			PUSH, _uv
			EXTERN, "UnityEngineVector2Array.__ctor__SystemInt32__UnityEngineVector2Array"

		# _uv2 = new Vector2[infoPageVertexCount]
			PUSH, infoPageVertexCount
			PUSH, _uv2
			EXTERN, "UnityEngineVector2Array.__ctor__SystemInt32__UnityEngineVector2Array"

		# _colors32 = new Color32[infoPageVertexCount]
			PUSH, infoPageVertexCount
			PUSH, _colors32
			EXTERN, "UnityEngineColor32Array.__ctor__SystemInt32__UnityEngineColor32Array"

		# _triangles = new Int32[infoPageIndexCount]
			PUSH, infoPageIndexCount
			PUSH, _triangles
			EXTERN, "SystemInt32Array.__ctor__SystemInt32__SystemInt32Array"

# -- setup sprite main loop variables --

# _vi0 = 0 ; _iptr = 0
	PUSH, _c_0
	PUSH, _vi0
	COPY
	PUSH, _c_0
	PUSH, _iptr
	COPY

# _vtxUV2 = Vector2(0.0, 1.0)
	PUSH, _cf_0
	PUSH, _cf_1
	PUSH, _vtxUV2
	EXTERN, "UnityEngineVector2.__ctor__SystemSingle_SystemSingle__UnityEngineVector2"

# -- sprite main loop --
# we use some special formatting here because this is going to get **DEEP**

_genGeomLoop:
	PUSH, _ofsPage
	PUSH, _endPage
	PUSH, _bool
	EXTERN, "SystemInt32.__op_Inequality__SystemInt32_SystemInt32__SystemBoolean"
	PUSH, _bool
	JUMP_IF_FALSE, _genGeomDone

	# -- sprite read-in --

		# _sprShape = *_ofsPage ; _ofsPage += 2
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _sprShape
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsPage
			PUSH, _c_2
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _sprTLX = *_ofsPage ; _ofsPage += 2
		# ** SIGNED ** (as opposed to unsigned like shape/col)
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _sprTLX
			EXTERN, "SystemBitConverter.__ToInt16__SystemByteArray_SystemInt32__SystemInt16"
			PUSH, _ofsPage
			PUSH, _c_2
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _sprTLY = *_ofsPage ; _ofsPage += 2
		# ** SIGNED ** (as opposed to unsigned like shape/col)
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _sprTLY
			EXTERN, "SystemBitConverter.__ToInt16__SystemByteArray_SystemInt32__SystemInt16"
			PUSH, _ofsPage
			PUSH, _c_2
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _sprCol = *_ofsPage ; _ofsPage += 2
			PUSH, bytes
			PUSH, _ofsPage
			PUSH, _sprCol
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsPage
			PUSH, _c_2
			PUSH, _ofsPage
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

	# -- find shape --

		# _ofsShape = int32(_sprShape)
			PUSH, _sprShape
			PUSH, _ofsShape
			EXTERN, "SystemConvert.__ToInt32__SystemUInt16__SystemInt32"
		# _ofsShape *= 16
			PUSH, _ofsShape
			PUSH, _c_16
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Multiplication__SystemInt32_SystemInt32__SystemInt32"
		# _ofsShape += _ofsAtlas
			PUSH, _ofsShape
			PUSH, _ofsAtlas
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"

	# -- shape read-in --

		# _shpUTLX = *_ofsShape ; _ofsShape += 2
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpUTLX
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsShape
			PUSH, _c_2
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _shpUTLY = *_ofsShape ; _ofsShape += 2
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpUTLY
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsShape
			PUSH, _c_2
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _shpUBRX = *_ofsShape ; _ofsShape += 2
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpUBRX
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsShape
			PUSH, _c_2
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _shpUBRY = *_ofsShape ; _ofsShape += 2
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpUBRY
			EXTERN, "SystemBitConverter.__ToUInt16__SystemByteArray_SystemInt32__SystemUInt16"
			PUSH, _ofsShape
			PUSH, _c_2
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _shpSizeX = *_ofsShape ; _ofsShape += 4
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpSizeX
			EXTERN, "SystemBitConverter.__ToSingle__SystemByteArray_SystemInt32__SystemSingle"
			PUSH, _ofsShape
			PUSH, _c_4
			PUSH, _ofsShape
			EXTERN, "SystemInt32.__op_Addition__SystemInt32_SystemInt32__SystemInt32"
		# _shpSizeY = *_ofsShape
			PUSH, bytes
			PUSH, _ofsShape
			PUSH, _shpSizeY
			EXTERN, "SystemBitConverter.__ToSingle__SystemByteArray_SystemInt32__SystemSingle"

	# -- colour decoding --

		# _col_i32 = int32(_sprCol)
			PUSH, _sprCol
			PUSH, _col_i32
			EXTERN, "SystemConvert.__ToInt32__SystemUInt16__SystemInt32"

		# _col_r = float(_col_i32 >> 11)
			PUSH, _col_i32
			PUSH, _i32
			COPY
			PUSH, _i32
			PUSH, _c_11
			PUSH, _i32
			EXTERN, "SystemInt32.__op_RightShift__SystemInt32_SystemInt32__SystemInt32"
			PUSH, _i32
			PUSH, _col_r
			EXTERN, "SystemConvert.__ToSingle__SystemInt32__SystemSingle"

		# _col_g = float((_col_i32 >> 5) & 0x3F)
			PUSH, _col_i32
			PUSH, _i32
			COPY
			PUSH, _i32
			PUSH, _c_5
			PUSH, _i32
			EXTERN, "SystemInt32.__op_RightShift__SystemInt32_SystemInt32__SystemInt32"
			PUSH, _i32
			PUSH, _c_63
			PUSH, _i32
			EXTERN, "SystemInt32.__op_LogicalAnd__SystemInt32_SystemInt32__SystemInt32"
			PUSH, _i32
			PUSH, _col_g
			EXTERN, "SystemConvert.__ToSingle__SystemInt32__SystemSingle"

		# _col_b = float(_col_i32 & 0x1F)
			PUSH, _col_i32
			PUSH, _i32
			COPY
			PUSH, _i32
			PUSH, _c_31
			PUSH, _i32
			EXTERN, "SystemInt32.__op_LogicalAnd__SystemInt32_SystemInt32__SystemInt32"
			PUSH, _i32
			PUSH, _col_b
			EXTERN, "SystemConvert.__ToSingle__SystemInt32__SystemSingle"

		# _col_r /= 31.0, _col_g /= 63.0, _col_b /= 31.0
			PUSH, _col_r
			PUSH, _cf_31
			PUSH, _col_r
			EXTERN, "SystemSingle.__op_Division__SystemSingle_SystemSingle__SystemSingle"
			PUSH, _col_g
			PUSH, _cf_63
			PUSH, _col_g
			EXTERN, "SystemSingle.__op_Division__SystemSingle_SystemSingle__SystemSingle"
			PUSH, _col_b
			PUSH, _cf_31
			PUSH, _col_b
			EXTERN, "SystemSingle.__op_Division__SystemSingle_SystemSingle__SystemSingle"

		# _col = Color(_col_r, _col_g, _col_b)
			PUSH, _col_r
			PUSH, _col_g
			PUSH, _col_b
			PUSH, _col
			EXTERN, "UnityEngineColor.__ctor__SystemSingle_SystemSingle_SystemSingle__UnityEngineColor"

		# _col = _col.linear
			PUSH, _col
			PUSH, _col
			EXTERN, "UnityEngineColor.__get_linear__UnityEngineColor"

		# _col32 = Color32(_col)
			PUSH, _col
			PUSH, _col32
			EXTERN, "UnityEngineColor32.__op_Implicit__UnityEngineColor__UnityEngineColor32"

	# -- find vertex indices --
	# these are also used to *write* the vertices, so indices should be figured out first.

		PUSH, _vi0
		PUSH, _c_1
