#!/bin/sh -e
# kip32 SDK setup script -- run on a Unix-like or MSYS2

if [ "$KIP32_SDK" = "" ]; then
	WHERE_AM_I="`readlink -f "$0"`"
	export KIP32_SDK="`dirname "$WHERE_AM_I"`"
fi

cd "$KIP32_SDK"

echo "kip32 SDK: $KIP32_SDK"
echo "MSYSTEM (MSYS2): $MSYSTEM"

if [ "$MSYSTEM" != "" ]; then
	if [ "$MSYSTEM" != "MINGW64" ]; then
		echo "Warning! This is probably MSYS2, but is not the MINGW64 environment. You might have problems."
	fi
fi

# -- STEP 1: SCRIPT SETUP --

write_tab() {
	printf "\t"
}

# comment
write_header() {
	echo "#!/bin/sh -e"
	echo "# $1"
	echo
	echo "export KIP32_SDK='$KIP32_SDK'"
	echo
}

# tool, specs, comment
write_gccthunk() {
	write_header "$3"
	echo "# this option exists so that science.c can avoid using M-extension instructions during most tests"
	echo 'if [ "$KIP32CC_OVERRIDE_ARCH" != "" ]; then'
	write_tab
	echo 'KIP32CC_ARCH="$KIP32CC_OVERRIDE_ARCH"'
	echo 'else'
	write_tab
	echo 'KIP32CC_ARCH="rv32im"'
	echo 'fi'
	echo
	echo 'exec riscv64-unknown-elf-'"$1"' -mabi=ilp32 "-march=$KIP32CC_ARCH" -ffreestanding -specs="$KIP32_SDK/'"$2"'.specs" "$@"'
}

# base, specs, comment
put_gccthunks() {
	write_gccthunk gcc "$2" "$3" > "bin/kip32-$1-gcc"
	write_gccthunk g++ "$2" "$3" > "bin/kip32-$1-g++"
	chmod +x "bin/kip32-$1-gcc" "bin/kip32-$1-g++"
}

write_sourceme() {
	echo "# This is a 'sourcable' script."
	echo "# By running it with '. ./env.sh' or somesuch, it adds the commands into your environment."
	echo "# Neat, huh?"
	echo "export KIP32_SDK='$KIP32_SDK'"
	echo "export PATH=\"$KIP32_SDK/bin:$PATH\""
}

write_elf2uasm_thunk() {
	write_header
	echo 'exec "$KIP32_SDK/bin/kip32-elf2uasm-bin" "$@"'
}

put_gccthunks libcqemu libcqemu "This is useful for testing the libc (or for testing code tightly coupled to the libc)."
put_gccthunks udon kip32_udon "Kind of like emcc in spirit. Adds kip32 SDK linker script, specs, include dirs, libc."

write_sourceme > env.sh

# clear legacy, setup elf2uasm thunk that sets KIP32_SDK correctly
rm -f "bin/kip32-elf2uasm"
write_elf2uasm_thunk > "bin/kip32-elf2uasm"
chmod +x "bin/kip32-elf2uasm"

# -- STEP 2: COMPILE FRONTEND --

link_tool() {
	rm -f "bin/$2" "bin/$2.exe"
	ln -s "../../tools/target/debug/$1" "bin/$2"
	ln -s "../../tools/target/debug/$1.exe" "bin/$2.exe"
}

compile_frontend() {
	set -e
	cargo build --manifest-path ../tools/Cargo.toml
	link_tool kip32-elf2uasm kip32-elf2uasm-bin
	link_tool kip32-corestub kip32-corestub
}

compile_frontend

# -- STEP 3: COMPILE LIBC --

compile_libc() {
	set -e
	cd libc
	rm -f obj/*.o obj_specific/*.o obj_kip32/*.o obj_qemu/*.o ../libcudon.a ../libcqemu.a
	echo -n "Compiling libc "
	../recipe "../bin/kip32-udon-gcc -g -O3" "-c -o" "" `cat objects.txt`
	riscv64-unknown-elf-ar rcs ../libcudon.a obj/*.o obj_kip32/*.o
	riscv64-unknown-elf-ar rcs ../libcqemu.a obj/*.o obj_qemu/*.o \
		obj_specific/memmove_slow.o
}

compile_libc

# -- STEP 4: CONGRATULATIONS --

echo " ... SDK setup complete!"
echo " You can add the bin/ directory to your PATH or run scripts from there directly in order to build programs."
echo " o pali pona! :3"
