code = "shader_type canvas_item;
uniform float SDFSmooth = 8;



void vertex() {
// Output:0

}

void fragment() {
// Texture:3
	vec3 n_out3p0;
	float n_out3p1;
	{
		vec4 _tex_read = texture(TEXTURE , UV.xy);
		n_out3p0 = _tex_read.rgb;
		n_out3p1 = _tex_read.a;
	}

// VectorDecompose:28
	float n_out28p0 = n_out3p0.x;
	float n_out28p1 = n_out3p0.y;
	float n_out28p2 = n_out3p0.z;

// Compare:32
	float n_in32p1 = 0.00000;
	bool n_out32p0 = n_out28p2>n_in32p1;

// Input:7
	vec3 n_out7p0 = COLOR.rgb;

// VectorSwitch:30
	vec3 n_out30p0;
	if(n_out32p0)
	{
		n_out30p0 = n_out3p0;
	}
	else
	{
		n_out30p0 = n_out7p0;
	}

// Input:24
	float n_out24p0 = COLOR.a;

// ScalarOp:8
	float n_in8p1 = 0.50000;
	float n_out8p0 = n_out3p1 - n_in8p1;

// Input:15
	vec3 n_out15p0 = vec3(UV, 0.0);

// Input:14
	vec3 n_out14p0 = vec3(TEXTURE_PIXEL_SIZE, 1.0);

// VectorOp:16
	vec3 n_out16p0 = n_out15p0 / n_out14p0;

// VectorDerivativeFunc:13
	vec3 n_out13p0 = fwidth(n_out16p0);

// VectorFunc:21
	vec3 n_out21p0 = abs(n_out13p0);

// VectorDecompose:17
	float n_out17p0 = n_out21p0.x;
	float n_out17p1 = n_out21p0.y;
	float n_out17p2 = n_out21p0.z;

// ScalarOp:18
	float n_out18p0 = max(n_out17p0, n_out17p1);

// ScalarUniform:29
	float n_out29p0 = SDFSmooth;

// ScalarOp:26
	float n_in26p1 = 128.00000;
	float n_out26p0 = n_out29p0 / n_in26p1;

// ScalarOp:20
	float n_out20p0 = n_out18p0 * n_out26p0;

// ScalarOp:19
	float n_out19p0 = n_out8p0 / n_out20p0;

// ScalarOp:11
	float n_in11p1 = 0.50000;
	float n_out11p0 = n_out19p0 + n_in11p1;

// ScalarFunc:27
	float n_out27p0 = min(max(n_out11p0, 0.0), 1.0);

// ScalarOp:25
	float n_out25p0 = n_out24p0 * n_out27p0;

// ScalarSwitch:31
	float n_out31p0;
	if(n_out32p0)
	{
		n_out31p0 = n_out3p1;
	}
	else
	{
		n_out31p0 = n_out25p0;
	}

// Output:0
	COLOR.rgb = n_out30p0;
	COLOR.a = n_out31p0;

}

